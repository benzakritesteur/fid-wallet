# Copy to terraform.tfvars and fill in values.
# NEVER commit terraform.tfvars to git.
#
# project_id  = "my-fidelity-project"
# env         = "dev"
# app_name    = "fidelity"
# region      = "europe-west1"
# github_owner = "my-github-org"
# github_repo  = "fidelity-backend"
#

# Secret Manager secret resource IDs (must be created manually):
# db_password_secret_id = "projects/your-project/secrets/db-password"
# apple_cert_base64_secret_id = "projects/your-project/secrets/apple-cert-base64"
# apple_cert_password_secret_id = "projects/your-project/secrets/apple-cert-password"
# google_wallet_service_account_key_secret_id = "projects/your-project/secrets/google-wallet-sa-key"
# whatsapp_api_token_secret_id = "projects/your-project/secrets/whatsapp-api-token"

